# Supabase configuration
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# Solana program ID (replace after anchor deploy)
VITE_SOLANA_PROGRAM_ID="CMTRgstry1111111111111111111111111111111111"

# Solana cluster: devnet | mainnet-beta
VITE_SOLANA_CLUSTER="devnet"

# Helius API key (optional) — enables Smart Money detection and enhanced
# transaction labeling. Free tier works fine. Sign up at https://helius.dev.
# When empty, the app falls back to public RPC and hides the feature gracefully.
VITE_HELIUS_API_KEY=""
